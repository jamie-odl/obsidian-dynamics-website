{
  "buildCommand": "node scripts/build-offline.mjs",
  "outputDirectory": "offline-dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/public/coverage",
      "destination": "/api/public-coverage-proxy"
    },
    {
      "source": "/api/intelligence/:path*",
      "destination": "/api/intelligence-proxy?upstream=:path*"
    },
    {
      "source": "/admin",
      "destination": "https://obsidian-dynamics-admin.vercel.app/admin"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://obsidian-dynamics-admin.vercel.app/admin/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "civitas.weareobsidian.co.uk"
        }
      ],
      "destination": "https://www.weareobsidian.co.uk/",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [
        {
          "type": "host",
          "value": "civitas.weareobsidian.co.uk"
        }
      ],
      "destination": "https://www.weareobsidian.co.uk/:path+",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "weareobsidian.co.uk"
