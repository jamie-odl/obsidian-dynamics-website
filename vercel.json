{
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/platform", "destination": "/products", "permanent": true },
    { "source": "/platform.html", "destination": "/products", "permanent": true },
    { "source": "/billing", "destination": "/", "permanent": true },
    { "source": "/billing.html", "destination": "/", "permanent": true },
    { "source": "/status", "destination": "/", "permanent": true },
    { "source": "/status.html", "destination": "/", "permanent": true },
    { "source": "/methodology", "destination": "/", "permanent": true },
    { "source": "/methodology.html", "destination": "/", "permanent": true },
    { "source": "/evidence-library", "destination": "/", "permanent": true },
    { "source": "/evidence-library.html", "destination": "/", "permanent": true },
    { "source": "/intelligence", "destination": "/products", "permanent": true },
    { "source": "/intelligence.html", "destination": "/products", "permanent": true },
    { "source": "/about.html", "destination": "/about", "permanent": true },
    { "source": "/contact.html", "destination": "/contact", "permanent": true },
    { "source": "/privacy.html", "destination": "/privacy", "permanent": true },
    { "source": "/terms.html", "destination": "/terms", "permanent": true },
    { "source": "/security.html", "destination": "/security", "permanent": true },
    { "source": "/skygrid", "destination": "/products", "permanent": true },
    { "source": "/skygrid.html", "destination": "/products", "permanent": true },
    { "source": "/onboarding-skygrid", "destination": "/onboarding", "permanent": true },
    { "source": "/onboarding-skygrid.html", "destination": "/onboarding", "permanent": true },
    { "source": "/charongate.html", "destination": "/charongate", "permanent": true },
    { "source": "/acheronvault.html", "destination": "/acheronvault", "permanent": true },
    { "source": "/writing/what-a-real-backup-test-looks-like.html", "destination": "/writing/what-a-real-backup-test-looks-like", "permanent": true },
    { "source": "/writing/cron-is-not-a-verification-strategy.html", "destination": "/writing/cron-is-not-a-verification-strategy", "permanent": true },
    { "source": "/writing/what-drift-looks-like-in-practice.html", "destination": "/writing/what-drift-looks-like-in-practice", "permanent": true }
  ],
  "headers": [
    {
      "source": "/developer-central",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    },
    {
      "source": "/developer-central.html",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    },
    {
      "source": "/developer-login",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    },
    {
      "source": "/developer-login.html",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" }
      ]
    },
    {
      "source": "/(favicon\\.(?:svg|ico)|robots\\.txt|sitemap\\.xml)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Permissions-Policy", "value": "accelerometer=(), autoplay=(), browsing-topics=(), camera=(), clipboard-read=(), clipboard-write=(self), display-capture=(), encrypted-media=(), fullscreen=(self), gamepad=(), geolocation=(), gyroscope=(), hid=(), identity-credentials-get=(), idle-detection=(), interest-cohort=(), magnetometer=(), microphone=(), midi=(), otp-credentials=(), payment=(), picture-in-picture=(), publickey-credentials-create=(self), publickey-credentials-get=(self), screen-wake-lock=(), serial=(), speaker-selection=(), storage-access=(), usb=(), web-share=(self), window-management=(), xr-spatial-tracking=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; manifest-src 'self'; worker-src 'self'; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
